def pause_listening(self):
        """Pauses the mic hardware to prevent overflows while AI thinks."""
        if self.stream and self.stream.is_active():
            self.stream.stop_stream()
            print("\n[Audio] ⏸️ Mic paused while AI processes...")

    def resume_listening(self):
        """Wakes the mic back up and flushes out old ghost noise."""
        if self.stream and self.stream.is_stopped():
            # Flush the queue to prevent old keyboard clicks from lingering
            while not self.audio_queue.empty():
                self.audio_queue.get()
                
            self.stream.start_stream()
            print("[Audio] ▶️ Mic resumed. Ready for next input!")





def run(self):
        self.mic.start()
        print("\n=== Pipeline Active. Start speaking. Press Ctrl+C to stop. ===")
        
        try:
            while True:
                # Small sleep to prevent CPU hogging
                import time
                time.sleep(0.01) 
                
                chunk = self.mic.get_audio_chunk()
                final_text, partial_text = self.asr.process_chunk(chunk)
                
                if partial_text:
                    # Print partials on a single updating line
                    print(f"\r[ASR Partial]: {partial_text[:80].ljust(80)}", end="", flush=True)

                if final_text:
                    print(f"\n[ASR Final]: {final_text}")
                    
                    # 1. MUTING MIC: Prevent hardware crash and feedback loops
                    self.mic.pause_listening() 
                    
                    # 2. AI GENERATION: Heavy compute block
                    print("[LLM] Generating response...")
                    llm_response = self.llm.generate_response(final_text)
                    print(f"[LLM Output]: {llm_response}")
                    
                    # 3. AUDIO GENERATION
                    self.tts.synthesize(llm_response)
                    
                    # 4. WAKING MIC: Safe to listen again
                    self.mic.resume_listening()
                    print("\n=== Ready for your next sentence. ===")
                    
        except KeyboardInterrupt:
            print("\nShutting down pipeline...")
            self.mic.stop()
